{
  "annotations": {
    "list": []
  },
  "description": "Scaling events timeline, pod counts, and cost optimization metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Scaling Events Timeline",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(predictscale_scaling_events_total[5m])",
          "legendFormat": "{{ direction }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          }
        }
      }
    },
    {
      "title": "Total Scale-Up Events",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "predictscale_scaling_events_total{direction=\"up\"}",
          "legendFormat": "Scale Up",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" }
        }
      }
    },
    {
      "title": "Total Scale-Down Events",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "predictscale_scaling_events_total{direction=\"down\"}",
          "legendFormat": "Scale Down",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    },
    {
      "title": "Recommended vs Actual Replicas",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "predictscale_recommended_replicas",
          "legendFormat": "Recommended (PredictScale)",
          "refId": "A"
        },
        {
          "expr": "kube_deployment_status_replicas_ready{deployment=\"sample-app\"}",
          "legendFormat": "Actual Ready Pods",
          "refId": "B"
        },
        {
          "expr": "kube_deployment_spec_replicas{deployment=\"sample-app\"}",
          "legendFormat": "Desired Replicas",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5
          },
          "unit": "short",
          "decimals": 0
        }
      }
    },
    {
      "title": "Prediction Confidence at Scale Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "predictscale_prediction_confidence",
          "legendFormat": "Confidence",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.7 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["predictscale", "scaling"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "PredictScale - Scaling Activity",
  "uid": "predictscale-scaling",
  "version": 1
}
