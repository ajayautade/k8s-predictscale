# ============================================
# K8s PredictScale - Environment Variables
# ============================================

# ---- Prometheus ----
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_SCRAPE_INTERVAL=15

# ---- Prediction Engine ----
PREDICTION_INTERVAL=60          # How often to run predictions (seconds)
PREDICTION_HORIZON=10           # Number of future steps to predict
MODEL_PATH=./models             # Path to saved model artifacts
MIN_TRAINING_DATA_HOURS=72      # Minimum hours of data before LSTM activates

# ---- Scaling Controller ----
DRY_RUN=true                    # Set to false to enable actual scaling
TARGET_NAMESPACE=default        # K8s namespace of target deployments
TARGET_DEPLOYMENT=sample-app    # Deployment to scale
MIN_REPLICAS=2                  # Minimum pod count
MAX_REPLICAS=50                 # Maximum pod count
SCALE_UP_RATE=5                 # Max pods to add per minute
SCALE_DOWN_RATE=2               # Max pods to remove per minute
COOLDOWN_PERIOD=120             # Seconds between scaling events
CONFIDENCE_THRESHOLD=0.7        # Minimum prediction confidence to act

# ---- API Server ----
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ---- Alerts ----
SLACK_WEBHOOK_URL=              # Slack incoming webhook URL
ALERT_ENABLED=false

# ---- AWS (for production) ----
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
ECR_REPOSITORY=k8s-predictscale
